{
  "name": "blerpc-central-rn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "lint": "eslint src/ --ignore-pattern 'src/proto/'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "proto": "pbjs -t static-module -w commonjs -o src/proto/blerpc.js ../proto/blerpc.proto && pbts -o src/proto/blerpc.d.ts src/proto/blerpc.js"
  },
  "dependencies": {
    "@blerpc/protocol-rn": "file:../../blerpc-protocol-rn",
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "buffer": "^6.0.3",
    "fast-text-encoding": "^1.0.6",
    "protobufjs": "^7.4.0",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-ble-plx": "^3.2.1",
    "react-native-get-random-values": "^1.11.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@eslint/js": "^9.19.0",
    "@react-native-community/cli": "^20.1.2",
    "@react-native/babel-preset": "0.79.2",
    "@react-native/metro-config": "0.79.2",
    "@react-native/typescript-config": "0.79.2",
    "@types/react": "^19.0.0",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "protobufjs-cli": "^1.1.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0"
  },
  "engines": {
    "node": ">=18"
  }
}
